<?xml version="1.0" encoding="utf-8"?>
<!-- Premium emoji reaction card -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#15FFFFFF"
                android:endColor="#08FFFFFF"
                android:type="linear"/>
            <corners android:radius="@dimen/corner_radius_xl"/>
        </shape>
    </item>
    
    <!-- Border -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#20FFFFFF"/>
            <corners android:radius="@dimen/corner_radius_xl"/>
        </shape>
    </item>
</layer-list>

