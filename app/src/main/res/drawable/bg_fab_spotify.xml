<?xml version="1.0" encoding="utf-8"?>
<!-- Spotify-style FAB with green glow -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow effect -->
    <item
        android:top="2dp"
        android:left="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="oval">
            <solid android:color="#401ED760"/>
        </shape>
    </item>
    
    <!-- Main button -->
    <item
        android:top="4dp"
        android:left="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="oval">
            <solid android:color="@color/spotify_green"/>
        </shape>
    </item>
</layer-list>

